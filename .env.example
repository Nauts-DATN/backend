# Server
PORT=4000
NODE_ENV=development

# JWT (bắt buộc) — dùng chuỗi dài, ngẫu nhiên trong production
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
# Base URL API — Swagger + link xác thực email trong email (GET /api/auth/verify-email?token=...)
# PUBLIC_API_URL=http://127.0.0.1:4000

# Email (tuỳ chọn — không cấu SMTP thì link xác thực chỉ in ra console khi đăng ký / gửi lại)
# EMAIL_FROM=EduAI <noreply@example.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_VERIFICATION_EXPIRES_HOURS=24

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/eduai

# DB — migration / seed khi khởi động server (tuỳ chọn)
# RUN_MIGRATIONS_ON_STARTUP=true
# RUN_SEEDS_ON_STARTUP=true

# Seed admin lần đầu (tuỳ chọn — seed 001_admin_bootstrap)
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=change-me-strong
# ADMIN_BOOTSTRAP_NAME=Admin

# MinIO / S3-compatible (AWS SDK)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=eduai-files
# Set true when using MinIO over HTTP (dev)
S3_FORCE_PATH_STYLE=true
