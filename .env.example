# Server
PORT=4000
NODE_ENV=development
# Base URL hiển thị trong Swagger (Try it out). Mặc định: http://localhost:{PORT}
# PUBLIC_API_URL=http://127.0.0.1:4000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/eduai

# MinIO / S3-compatible (AWS SDK)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=eduai-files
# Set true when using MinIO over HTTP (dev)
S3_FORCE_PATH_STYLE=true
